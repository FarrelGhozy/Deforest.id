# ── Google Earth Engine ──
GEE_PROJECT=deforestprojek
GEE_CREDENTIALS=path/to/service-account-key.json

# ── GEE OAuth (untuk login via web pake akun pribadi) ──
# Buat OAuth 2.0 Client ID di https://console.cloud.google.com/apis/credentials
# Tipe: Web Application, Redirect URI: http://localhost:5000/callback
GEE_OAUTH_CLIENT_ID=
GEE_OAUTH_CLIENT_SECRET=

# ── PostgreSQL / PostGIS ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=deforest
DB_USER=deforest
DB_PASSWORD=

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Backend API ──
JWT_SECRET=

# ── WhatsApp Bot ──
SESSION_ENCRYPTION_KEY=

# ── KLHK SIGAP Geoportal (optional) ──
KLHK_API_KEY=

# ── BIG Satupeta (optional) ──
BIG_API_KEY=
